# Stock Research API - Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=sqlite:///./stock_data.db

# Stock data source
# Production defaults to real data. Set USE_REAL_DATA=false only for local mock mode.
USE_REAL_DATA=false
# Required when USE_REAL_DATA=true:
POLYGON_API_KEY=your_polygon_key_here
# Optional, supplements Polygon with earnings estimates:
FINNHUB_API_KEY=your_finnhub_key_here

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:5173

# App authentication (Basic Auth + signed session cookie)
APP_AUTH_USERNAME=palmer
APP_AUTH_PASSWORD=
# Secret used to sign session cookies. Set this to a long random value so a
# leaked session token can't be brute-forced back into the password. Falls back
# to APP_AUTH_PASSWORD when unset.
APP_SESSION_SECRET=
# Trust X-Forwarded-For / proxy headers for the client IP. Enable only behind a
# trusted reverse proxy (Railway/Vercel). TRUSTED_PROXY_HOPS is how many such
# proxies sit in front of the app — the client IP is read that many hops from
# the right of X-Forwarded-For.
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_HOPS=1

# Bitcoin Chat
BITCOIN_RPC_URL=http://127.0.0.1:8332
BITCOIN_RPC_USER=your_rpc_user
BITCOIN_RPC_PASSWORD=your_rpc_password
BITCOIN_RPC_TIMEOUT_SECONDS=10
BITCOIN_NETWORK=main
BITCOIN_MAX_MINED_STATS_BLOCKS=1008
BITCOIN_CHAT_MAX_TOOL_CALLS=6
BITCOIN_CHAT_MODEL_TIMEOUT_SECONDS=30
BITCOIN_CHAT_MAX_SESSION_MESSAGES=12
BITCOIN_CHAT_MODEL=gpt-5.5
BITCOIN_CHAT_REASONING_EFFORT=low
BITCOIN_CHAT_VERBOSITY=medium

# Craps strategy simulator — plain-English -> StrategyIntent translation.
# Without OPENAI_API_KEY the /api/craps/translate endpoint returns 503 and the
# frontend falls back to built-in preset strategies.
CRAPS_STRATEGY_MODEL=gpt-5.5
CRAPS_STRATEGY_MODEL_TIMEOUT_SECONDS=30
CRAPS_TRANSLATE_RATE_LIMIT_WINDOW_SECONDS=60
CRAPS_TRANSLATE_RATE_LIMIT_MAX=20

# Enables natural-language Bitcoin AI responses. Without this, Bitcoin Chat
# falls back to deterministic read-only node answers.
OPENAI_API_KEY=your_openai_api_key

# Fantasy football dashboard (spec 16)
# The background data collector always runs; per-job next-due timestamps in
# the DB keep restarts cheap, and odds jobs self-skip without ODDS_API_KEY.
# Sleeper (free, no key) — override only for testing against a mock host.
# SLEEPER_API_URL=https://api.sleeper.app/v1
# SLEEPER_DATA_URL=https://api.sleeper.com
# ESPN fantasy projections are keyless. Override only for mock testing.
# ESPN_FANTASY_API_URL=https://lm-api-reads.fantasy.espn.com/apis/v3/games/ffl
# nflverse CSV feeds ({season} is substituted for the weekly-stats URL).
# NFLVERSE_GAMES_URL=https://raw.githubusercontent.com/nflverse/nfldata/master/data/games.csv
# NFLVERSE_WEEKLY_STATS_URL=https://github.com/nflverse/nflverse-data/releases/download/player_stats/player_stats_{season}.csv
# The Odds API (betting layer, P3). Free tier is 500 credits/month; the
# collector refuses calls that would push the month over the budget.
# ODDS_API_KEY=your_odds_api_key
ODDS_API_MONTHLY_BUDGET=450
# FantasyPros projections (optional second selectable source). Without it,
# the dashboard continues to use Sleeper projections only.
# FANTASYPROS_API_KEY=your_fantasypros_key
FANTASY_CHAT_MODEL=gpt-5.5
FANTASY_FEATURED_GAMES=4
