{
  "name": "palmergill-site",
  "version": "1.0.0",
  "description": "Personal project site with shared API-backed apps",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@vercel/functions": "^3.5.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": [
      "poker/tests",
      "craps/tests",
      "blackjack/tests",
      "craps-strategy/tests",
      "shared/tests"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "poker/**/*.js",
      "craps-strategy/**/*.js",
      "shared/*.js",
      "!craps-strategy/tests/**",
      "!poker/tests/**",
      "!shared/tests/**",
      "!**/node_modules/**"
    ]
  }
}
